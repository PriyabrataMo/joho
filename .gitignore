# Build output
engine/build/
build/

# Editor / tooling artifacts (generated; embed absolute local paths)
.cache/
compile_commands.json

# Data: downloaded corpora and built indexes (can be large) — never commit
data/

# Python
__pycache__/
*.pyc
.venv/
venv/

# Node / Next.js
node_modules/
.next/
out/

# OS / editor
.DS_Store
*.swp
.vscode/

# Secrets / local env (keep the .example files, ignore real ones)
.env
.env.local
.env.*.local
.env.aws
*.key
*.pem
service-account*.json

# AWS deploy runtime artifacts (private key / cached security-group id / last instance id)
deploy/aws/.sg_id
deploy/aws/.last_instance

# Generated gRPC stubs (regenerated by scripts/gen_proto.sh)
gateway/joho_pb/

# Local design/working notes — not part of the published codebase
docs/
